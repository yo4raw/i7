---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchSongsJson } from '../../lib/data/fetchSongsJson.js';

export async function getStaticPaths() {
  const allSongs = (await fetchSongsJson() as any[]).filter((s: any) => s.category && s.artist && s.notes_count);
  return allSongs.map((song: any) => ({
    params: { id: String(song.id) },
    props: { song },
  }));
}

const { song } = Astro.props;
const base = import.meta.env.BASE_URL;

// 属性比率の円グラフ用
const sr = song.shout_ratio || 0;
const br = song.beat_ratio || 0;
const mr = song.melody_ratio || 0;
const totalRatio = sr + br + mr;
const sPct = totalRatio ? Math.round(sr * 100) : 0;
const bPct = totalRatio ? Math.round(br * 100) : 0;
const mPct = totalRatio ? Math.round(mr * 100) : 0;
const r = 15.9155;
const c = 2 * Math.PI * r;
const sLen = totalRatio ? (sr / totalRatio) * c : 0;
const bLen = totalRatio ? (br / totalRatio) * c : 0;
const mLen = totalRatio ? (mr / totalRatio) * c : 0;

// ノート内訳データ
const NOTE_GROUPS = [
  { key: 'notes_20', label: 'Notes 2.0' },
  { key: 'light_2', label: 'Light 2' },
  { key: 'light_3', label: 'Light 3' },
  { key: 'light_4', label: 'Light 4' },
  { key: 'light_5', label: 'Light 5' },
  { key: 'light_6', label: 'Light 6' },
  { key: 'chorus_light_5', label: 'Chorus Light 5' },
  { key: 'chorus_light_6', label: 'Chorus Light 6' },
];

const hasNoteData = NOTE_GROUPS.some(g => {
  const group = song[g.key];
  return group && Object.values(group).some((v: any) => v > 0);
});

// 基本情報
const infoRows = [
  { label: 'ID', value: song.id },
  { label: 'グループ', value: song.category },
  { label: 'アーティスト', value: song.artist },
  { label: '楽曲タイプ', value: song.song_type },
  { label: '難易度', value: song.difficulty ? `${song.difficulty}${song.stars ? ' ' + '★'.repeat(song.stars) + '☆'.repeat(Math.max(0, 5 - song.stars)) : ''}` : null },
  { label: 'ノーツ数', value: song.notes_count?.toLocaleString() },
  { label: '秒数', value: song.duration ? `${song.duration}秒` : null },
  { label: '更新日', value: song.updated_at },
].filter(r => r.value != null && r.value !== '');
---

<BaseLayout title={song.song_name || '楽曲詳細'}>
  <div class="mb-6">
    <a href={`${base}songs/`} class="text-indigo-600 hover:underline text-sm">&larr; 楽曲一覧に戻る</a>
  </div>

  <!-- 基本情報 -->
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h1 class="text-2xl font-bold mb-1">{song.song_name}</h1>
    <p class="text-gray-500 mb-4">{song.artist} / {song.category}</p>
    {song.stars && (
      <p class="text-amber-400 text-lg mb-4">{'★'.repeat(song.stars)}{'☆'.repeat(Math.max(0, 5 - song.stars))}</p>
    )}
    <table class="w-full text-sm">
      <tbody class="divide-y divide-gray-100">
        {infoRows.map(row => (
          <tr>
            <td class="py-2 pr-4 font-medium text-gray-500 w-1/3">{row.label}</td>
            <td class="py-2">{row.value}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- 属性比率 -->
  {totalRatio > 0 && (
    <section class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">属性比率</h2>
      <div class="flex flex-col sm:flex-row items-center gap-6">
        <div class="w-36 h-36 flex-shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full">
            <circle cx="18" cy="18" r={r} fill="none" stroke="#e5e7eb" stroke-width="4" />
            <circle cx="18" cy="18" r={r} fill="none" stroke="#ef4444" stroke-width="4"
              stroke-dasharray={`${sLen} ${c - sLen}`} stroke-dashoffset="0" transform="rotate(-90 18 18)" />
            <circle cx="18" cy="18" r={r} fill="none" stroke="#22c55e" stroke-width="4"
              stroke-dasharray={`${bLen} ${c - bLen}`} stroke-dashoffset={-sLen} transform="rotate(-90 18 18)" />
            <circle cx="18" cy="18" r={r} fill="none" stroke="#3b82f6" stroke-width="4"
              stroke-dasharray={`${mLen} ${c - mLen}`} stroke-dashoffset={-(sLen + bLen)} transform="rotate(-90 18 18)" />
          </svg>
        </div>
        <div class="space-y-2">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
            <span class="text-sm font-medium w-16">Shout</span>
            <span class="text-sm">{sPct}%</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>
            <span class="text-sm font-medium w-16">Beat</span>
            <span class="text-sm">{bPct}%</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-blue-500 inline-block"></span>
            <span class="text-sm font-medium w-16">Melody</span>
            <span class="text-sm">{mPct}%</span>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ノート内訳 -->
  {hasNoteData && (
    <section class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">ノート内訳</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-left text-xs text-gray-500">
              <th class="px-3 py-2">レベル</th>
              <th class="px-3 py-2 text-right text-red-500">S白</th>
              <th class="px-3 py-2 text-right text-red-500">S色</th>
              <th class="px-3 py-2 text-right text-green-500">B白</th>
              <th class="px-3 py-2 text-right text-green-500">B色</th>
              <th class="px-3 py-2 text-right text-blue-500">M白</th>
              <th class="px-3 py-2 text-right text-blue-500">M色</th>
              <th class="px-3 py-2 text-right font-semibold">計</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {NOTE_GROUPS.map(g => {
              const group = song[g.key] || {};
              const sw = group.shout_white || 0;
              const sc = group.shout_color || 0;
              const bw = group.beat_white || 0;
              const bc = group.beat_color || 0;
              const mw = group.melody_white || 0;
              const mc = group.melody_color || 0;
              const total = sw + sc + bw + bc + mw + mc;
              if (total === 0) return null;
              return (
                <tr class="hover:bg-gray-50">
                  <td class="px-3 py-2 font-medium">{g.label}</td>
                  <td class="px-3 py-2 text-right">{sw || '-'}</td>
                  <td class="px-3 py-2 text-right">{sc || '-'}</td>
                  <td class="px-3 py-2 text-right">{bw || '-'}</td>
                  <td class="px-3 py-2 text-right">{bc || '-'}</td>
                  <td class="px-3 py-2 text-right">{mw || '-'}</td>
                  <td class="px-3 py-2 text-right">{mc || '-'}</td>
                  <td class="px-3 py-2 text-right font-semibold">{total}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- 合計ノート数 -->
  {(song.total_shout_white || song.total_beat_white || song.total_melody_white) && (
    <section class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">合計ノート数</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-left text-xs text-gray-500">
              <th class="px-3 py-2">属性</th>
              <th class="px-3 py-2 text-right">白ノート</th>
              <th class="px-3 py-2 text-right">色ノート</th>
              <th class="px-3 py-2 text-right font-semibold">合計</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 font-medium text-red-500">Shout</td>
              <td class="px-3 py-2 text-right">{Math.round(song.total_shout_white || 0).toLocaleString()}</td>
              <td class="px-3 py-2 text-right">{Math.round(song.total_shout_color || 0).toLocaleString()}</td>
              <td class="px-3 py-2 text-right font-semibold">{Math.round((song.total_shout_white || 0) + (song.total_shout_color || 0)).toLocaleString()}</td>
            </tr>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 font-medium text-green-500">Beat</td>
              <td class="px-3 py-2 text-right">{Math.round(song.total_beat_white || 0).toLocaleString()}</td>
              <td class="px-3 py-2 text-right">{Math.round(song.total_beat_color || 0).toLocaleString()}</td>
              <td class="px-3 py-2 text-right font-semibold">{Math.round((song.total_beat_white || 0) + (song.total_beat_color || 0)).toLocaleString()}</td>
            </tr>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 font-medium text-blue-500">Melody</td>
              <td class="px-3 py-2 text-right">{Math.round(song.total_melody_white || 0).toLocaleString()}</td>
              <td class="px-3 py-2 text-right">{Math.round(song.total_melody_color || 0).toLocaleString()}</td>
              <td class="px-3 py-2 text-right font-semibold">{Math.round((song.total_melody_white || 0) + (song.total_melody_color || 0)).toLocaleString()}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  )}
</BaseLayout>
