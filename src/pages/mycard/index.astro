---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MyCardList from '../../components/MyCardList.svelte';
import { fetchCardsJson } from '../../lib/data/fetchCardsJson.ts';
import { CARD_THUMB_BASE_URL } from '../../lib/constants';

const allCards = await fetchCardsJson() as any[];
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="所持カード一覧">
  <h1 class="text-2xl font-bold mb-6">所持カード一覧</h1>

  <MyCardList cards={allCards} base={base} thumbUrl={CARD_THUMB_BASE_URL} client:load />
</BaseLayout>
