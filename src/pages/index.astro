---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchCardsJson } from '../lib/data/fetchCardsJson.ts';
import { fetchSongsJson } from '../lib/data/fetchSongsJson.ts';
import { fetchEventsCsv } from '../lib/data/fetchEventsCsv.ts';
import { RARITIES, RARITY_BADGE_CLASSES, SITE_NAME } from '../lib/constants.ts';

const [cards, songs, events] = await Promise.all([
  fetchCardsJson(),
  fetchSongsJson(),
  fetchEventsCsv(),
]);

const rarityCounts: Record<string, number> = {};
for (const card of cards as Array<{ rarity?: string }>) {
  const r = card.rarity || '不明';
  rarityCounts[r] = (rarityCounts[r] || 0) + 1;
}
const rarityEntries = RARITIES
  .map((r) => [r, rarityCounts[r] ?? 0] as const)
  .filter(([, n]) => n > 0);

const now = new Date();
const sortedEvents = [...events].sort((a, b) => b.id - a.id);
const liveEvents = sortedEvents.filter((ev) => {
  const start = new Date(`${ev.start_date}T17:00:00+09:00`);
  const end = new Date(`${ev.end_date}T17:00:00+09:00`);
  return start <= now && now < end;
});
const upcomingEvents = sortedEvents
  .filter((ev) => new Date(`${ev.start_date}T17:00:00+09:00`) > now)
  .sort((a, b) => a.start_date.localeCompare(b.start_date))
  .slice(0, 1);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="ホーム">
  <section class="mb-8">
    <h1 class="text-2xl font-bold mb-2">アイドリッシュセブン カードデータベース</h1>
    <p class="text-sm text-gray-600">
      当サイト「{SITE_NAME}」は、スマートフォン向けゲーム『アイドリッシュセブン』のカード・楽曲・イベント情報をまとめた、ファンによる<strong>非公式</strong>のデータベースサイトです。
    </p>
  </section>

  <section class="bg-white rounded-lg shadow p-6 mb-8">
    <h2 class="text-lg font-bold text-indigo-700 mb-3">サイトの目的</h2>
    <ul class="list-disc pl-5 space-y-1 text-sm text-gray-700">
      <li>アイドリッシュセブンのカード・楽曲情報を検索・閲覧しやすい形で提供する</li>
      <li>モンテカルロシミュレーションによるスコア計算など、プレイヤー向けのツールを提供する</li>
      <li>開催中イベントの特効カード情報を一覧で確認できるようにする</li>
      <li>所持カード・デッキ構成を手元で管理できる場を提供する</li>
    </ul>
  </section>

  {(liveEvents.length > 0 || upcomingEvents.length > 0) && (
    <section class="mb-8" id="event-highlight">
      <h2 class="text-lg font-bold text-indigo-700 mb-3">
        {liveEvents.length > 0 ? '開催中のイベント' : '次回イベント'}
      </h2>
      <ul class="space-y-2">
        {(liveEvents.length > 0 ? liveEvents : upcomingEvents).map((ev) => (
          <li
            class="event-item bg-white rounded-lg shadow p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2"
            data-start={`${ev.start_date}T17:00:00+09:00`}
            data-end={`${ev.end_date}T17:00:00+09:00`}
          >
            <div>
              <a href={`${base}events/${ev.id}/`} class="text-indigo-700 font-semibold hover:underline">
                {ev.eventname}
              </a>
              <div class="text-xs text-gray-500 mt-0.5">
                {ev.eventtype} / {ev.start_date} 17:00 〜 {ev.end_date} 17:00 (JST)
              </div>
            </div>
            <div class="flex items-center gap-3 text-xs">
              <span class="status-badge inline-block px-2 py-0.5 rounded font-semibold text-gray-500 bg-gray-100">—</span>
              <span class="status-remain text-gray-500"></span>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="mb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-lg font-bold text-indigo-700">主な機能</h2>
      <p class="text-xs text-gray-500">各ページはヘッダーナビゲーションからもアクセスできます</p>
    </div>

    <h3 class="text-sm font-semibold text-gray-600 mb-2">データベース</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
      <a href={`${base}cards/`}
         class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition-shadow">
        <h4 class="text-base font-semibold text-indigo-700 mb-1">カード一覧</h4>
        <p class="text-xs text-gray-600 mb-3">レアリティ・属性・キャラクター・スキルタイプで絞り込み可能。開催中イベントの特効フィルタや所持数入力にも対応。</p>
        <div class="text-2xl font-bold text-gray-800">{cards.length}<span class="text-sm text-gray-500 ml-1">枚</span></div>
      </a>
      <a href={`${base}songs/`}
         class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition-shadow">
        <h4 class="text-base font-semibold text-indigo-700 mb-1">楽曲一覧</h4>
        <p class="text-xs text-gray-600 mb-3">楽曲ごとのノーツ属性比率・Lv 別情報を確認。スコア計算へそのまま持ち込めます。</p>
        <div class="text-2xl font-bold text-gray-800">{songs.length}<span class="text-sm text-gray-500 ml-1">曲</span></div>
      </a>
      <a href={`${base}events/`}
         class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition-shadow">
        <h4 class="text-base font-semibold text-indigo-700 mb-1">イベント情報</h4>
        <p class="text-xs text-gray-600 mb-3">開催中・過去イベントの一覧と、各イベントの特効カード・効果量を確認できます。</p>
        <div class="text-2xl font-bold text-gray-800">{events.length}<span class="text-sm text-gray-500 ml-1">件</span></div>
      </a>
    </div>

    <h3 class="text-sm font-semibold text-gray-600 mb-2">プレイヤー向けツール</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href={`${base}mycard/`}
         class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition-shadow">
        <h4 class="text-base font-semibold text-indigo-700 mb-1">所持カード</h4>
        <p class="text-xs text-gray-600">手元にあるカードの所持数を入力・集計。レアリティ別の所持状況も一目で確認。</p>
      </a>
      <a href={`${base}score-calc/`}
         class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition-shadow">
        <h4 class="text-base font-semibold text-indigo-700 mb-1">スコア計算</h4>
        <p class="text-xs text-gray-600">デッキ・楽曲・ブローチを選び、モンテカルロシミュレーションでスコア分布を推定。</p>
      </a>
      <a href={`${base}rabbit-note/`}
         class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition-shadow">
        <h4 class="text-base font-semibold text-indigo-700 mb-1">ラビットノート</h4>
        <p class="text-xs text-gray-600">ラビットノートの投入レベルを入力し、スコア計算のベーススコアへ自動反映。</p>
      </a>
      <a href={`${base}decks/`}
         class="block bg-white rounded-lg shadow p-5 hover:shadow-md transition-shadow">
        <h4 class="text-base font-semibold text-indigo-700 mb-1">保存デッキ</h4>
        <p class="text-xs text-gray-600">構築したデッキを端末の localStorage に保存・呼び出し。名前を付けて使い分け可能。</p>
      </a>
    </div>
    <p class="text-xs text-gray-500 mt-4">
      所持カード数・ラビットノート値・保存デッキなどのユーザーデータは、閲覧している端末の <code class="px-1 py-0.5 bg-gray-100 rounded">localStorage</code> にのみ保存されます。サーバーへは送信されません。
    </p>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-indigo-700 mb-3">カード内訳</h2>
    <div class="bg-white rounded-lg shadow p-5">
      <div class="flex flex-wrap gap-2">
        {rarityEntries.map(([rarity, count]) => (
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-sm">
            <span class={`inline-block px-2 py-0.5 rounded text-xs font-bold text-white ${RARITY_BADGE_CLASSES[rarity] ?? 'bg-gray-400'}`}>{rarity}</span>
            <span class="text-gray-700">{count}<span class="text-xs text-gray-500 ml-0.5">枚</span></span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-indigo-700 mb-3">謝辞</h2>
    <dl class="text-sm text-gray-700 space-y-3 mb-4">
      <div class="flex flex-col sm:flex-row sm:gap-4">
        <dt class="font-semibold sm:w-40 shrink-0">各種データの取得元</dt>
        <dd>
          <a href="https://i7.step-on-dream.net/" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">i7.step-on-dream.net</a>
        </dd>
      </div>
      <div class="flex flex-col sm:flex-row sm:gap-4">
        <dt class="font-semibold sm:w-40 shrink-0">スコア計算の仕様参考</dt>
        <dd>
          <a href="https://ota-life.com/id7-score-tool/" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">オタライフ |【アイドリッシュセブン】スコア計算ツール無料配布【スマホ対応】</a>
        </dd>
      </div>
    </dl>
    <p class="text-sm text-gray-700 mb-2">
      本サイト作成の際、下記のお二人には多大なるお力添えをいただきました。感謝いたします。
    </p>
    <ul class="list-disc pl-5 space-y-1 text-sm text-gray-700">
      <li>
        <a href="https://x.com/megoonarite" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">@megoonarite</a>
      </li>
      <li>
        <a href="https://x.com/miyaaaaaki_i7" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">@miyaaaaaki_i7</a>
      </li>
    </ul>
  </section>

  <section class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-indigo-700 mb-3">お問い合わせ</h2>
    <p class="text-sm text-gray-700 mb-2">
      ご意見・ご要望・不具合報告・権利に関するお問い合わせは、以下のいずれかへお願いいたします。
    </p>
    <ul class="list-disc pl-5 space-y-1 text-sm text-gray-700">
      <li>
        X (旧Twitter): <a href="https://x.com/yo4raw_i7" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline">@yo4raw_i7</a>
      </li>
    </ul>
  </section>

  <section class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-indigo-700 mb-3">プライバシー</h2>
    <ul class="list-disc pl-5 space-y-1 text-sm text-gray-700">
      <li>所持カード・デッキ・ラビットノート値などのユーザー入力は、ブラウザの <code class="px-1 py-0.5 bg-gray-100 rounded">localStorage</code> のみに保存され、サーバーへ送信されません。</li>
      <li>データのエクスポート・完全削除はブラウザの設定または各ページ上のクリア機能から行えます。</li>
    </ul>
  </section>

  <section class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
    <h2 class="text-lg font-bold text-yellow-800 mb-3">免責事項・権利表記</h2>
    <ul class="list-disc pl-5 space-y-2 text-sm text-gray-800">
      <li>
        当サイトはアイドリッシュセブン運営・開発元とは一切関係のない、ファンによる<strong>非公式</strong>のデータベースサイトです。
      </li>
      <li>
        『アイドリッシュセブン』および関連するキャラクター・画像・楽曲・ロゴ等の著作権・商標権は、株式会社バンダイナムコオンライン、株式会社バンダイナムコエンターテインメント、株式会社バンダイナムコピクチャーズ、その他の権利者に帰属します。
      </li>
      <li>
        カード画像は利用者の利便性のために各ゲームサーバーより取得・キャッシュしているものであり、画像そのものの権利は元の権利者に帰属します。画像・データの無断転載・商用利用はご遠慮ください。
      </li>
      <li>
        当サイトに掲載されている数値・仕様・スコア計算結果は、有志による計測・推定値を含みます。ゲーム内の挙動と完全に一致することを保証するものではありません。
      </li>
      <li>
        当サイトの利用により生じたいかなる損害についても、運営者は責任を負いません。
      </li>
      <li>
        権利者様からの削除・修正依頼がございましたら、上記「お問い合わせ」の連絡先までご連絡ください。
      </li>
    </ul>
  </section>
</BaseLayout>

<script>
  function formatRemain(ms: number): string {
    if (ms <= 0) return '';
    const totalMin = Math.floor(ms / 60000);
    const d = Math.floor(totalMin / (60 * 24));
    const h = Math.floor((totalMin % (60 * 24)) / 60);
    const m = totalMin % 60;
    if (d > 0) return `残り ${d}日 ${h}時間`;
    if (h > 0) return `残り ${h}時間 ${m}分`;
    return `残り ${m}分`;
  }

  function refresh(): void {
    const now = Date.now();
    const items = document.querySelectorAll<HTMLElement>('#event-highlight .event-item');
    for (const el of items) {
      const start = new Date(el.dataset.start ?? '').getTime();
      const end = new Date(el.dataset.end ?? '').getTime();
      const badge = el.querySelector<HTMLElement>('.status-badge');
      const remain = el.querySelector<HTMLElement>('.status-remain');
      if (!badge || !remain) continue;
      if (Number.isNaN(start) || Number.isNaN(end)) continue;

      if (now < start) {
        badge.textContent = '開催予定';
        badge.className = 'status-badge inline-block px-2 py-0.5 rounded font-semibold text-blue-700 bg-blue-100';
        remain.textContent = `開始まで ${formatRemain(start - now)}`;
      } else if (now < end) {
        badge.textContent = '実施中';
        badge.className = 'status-badge inline-block px-2 py-0.5 rounded font-semibold text-red-700 bg-red-100';
        remain.textContent = formatRemain(end - now);
      } else {
        badge.textContent = '終了';
        badge.className = 'status-badge inline-block px-2 py-0.5 rounded font-semibold text-gray-500 bg-gray-200';
        remain.textContent = '';
      }
    }
  }

  refresh();
  setInterval(refresh, 60_000);
</script>
