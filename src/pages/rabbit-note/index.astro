---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RabbitNoteEditor from '../../components/RabbitNoteEditor.svelte';
---

<BaseLayout title="ラビットノート">
  <h1 class="text-2xl font-bold mb-4">ラビットノート</h1>
  <p class="text-sm text-gray-600 dark:text-slate-300 mb-6">各キャラクターのラビットノート値を入力してください。スコア計算時に各衣装の素点に加算されます。</p>

  <RabbitNoteEditor client:load />
</BaseLayout>
