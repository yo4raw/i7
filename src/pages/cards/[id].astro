---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchCardsJson } from '../../lib/data/fetchCardsJson.js';
import { fetchFixedBroachsJson } from '../../lib/data/fetchFixedBroachsJson.js';
import { CARD_IMAGE_BASE_URL, ATTRIBUTE_MAP } from '../../lib/constants';

import { ATTRIBUTE_COLORS, ATTRIBUTE_BADGE_CLASSES } from '../../lib/constants';

const ATTR_COLORS = ATTRIBUTE_COLORS;
const RARITY_COLORS: Record<string, string> = {
  UR: 'bg-amber-500', SSR: 'bg-purple-500', SR: 'bg-sky-400', R: 'bg-gray-400', GROUP: 'bg-pink-400',
};
const ATTR_BADGE_COLORS: Record<string, string> = { Shout: 'bg-red-500', Beat: 'bg-green-500', Melody: 'bg-blue-500' };

export async function getStaticPaths() {
  const [cards, broachs] = await Promise.all([fetchCardsJson(), fetchFixedBroachsJson()]);
  return (cards as any[]).map((card: any) => ({
    params: { id: String(card.ID) },
    props: {
      card,
      broachs: (broachs as any[]).filter((b: any) => b.card_id === card.cardID),
    },
  }));
}

const { card, broachs } = Astro.props;
const base = import.meta.env.BASE_URL;

const infoRows = [
  { label: 'ID', value: card.ID },
  { label: 'カードID', value: card.cardID },
  { label: 'キャラクター', value: card.name },
  { label: 'グループ', value: card.groupname },
  { label: '入手方法', value: card.get_type },
  { label: 'ストーリー', value: card.story },
].filter(r => r.value != null && r.value !== '');

const stats = [
  { label: 'Shout', min: card.shout_min || 0, max: card.shout_max || 0, color: ATTR_COLORS[1] },
  { label: 'Beat', min: card.beat_min || 0, max: card.beat_max || 0, color: ATTR_COLORS[2] },
  { label: 'Melody', min: card.melody_min || 0, max: card.melody_max || 0, color: ATTR_COLORS[3] },
];

const apSkillLevels = [];
if (card.ap_skill_name) {
  for (let i = 1; i <= 5; i++) {
    const count = card[`ap_skill_${i}_count`];
    const per = card[`ap_skill_${i}_per`];
    const value = card[`ap_skill_${i}_value`];
    const rate = card[`ap_skill_${i}_rate`];
    if (count != null || per != null || value != null || rate != null) {
      apSkillLevels.push({ lv: i, count, per, value, rate });
    }
  }
}

const otherSkills = [
  { label: 'センタースキル', value: card.ct_skill },
  { label: 'SPスキル時間', value: card.sp_time },
  { label: 'SPスキル値', value: card.sp_value },
  { label: 'コメント', value: card.comment },
].filter(r => r.value != null && r.value !== '');
---

<BaseLayout title={card.cardname || 'カード詳細'}>
  <div class="mb-6">
    <a href={`${base}cards/`} class="text-indigo-600 hover:underline text-sm">&larr; カード一覧に戻る</a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="md:col-span-1">
      <img src={`${CARD_IMAGE_BASE_URL}/${card.ID}.png`} alt={card.cardname || ''}
           class="w-full rounded-lg shadow-md bg-gray-200"
           onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 200 280%22><rect width=%22200%22 height=%22280%22 fill=%22%23e5e7eb%22/><text x=%2250%25%22 y=%2250%25%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 fill=%22%239ca3af%22 font-size=%2216%22>No Image</text></svg>'" />
    </div>
    <div class="md:col-span-2">
      <h1 class="text-2xl font-bold mb-4">
        <span class={`inline-block px-2 py-0.5 text-xs font-bold text-white rounded ${RARITY_COLORS[card.rarity] || 'bg-gray-300'}`}>{card.rarity}</span>
        <span class={`inline-block px-2 py-0.5 text-xs font-bold text-white rounded ${ATTR_BADGE_COLORS[card.attribute] || 'bg-gray-300'}`}>{card.attribute || '不明'}</span>
        {card.cardname || ''}
      </h1>
      <table class="w-full text-sm">
        <tbody class="divide-y divide-gray-100">
          {infoRows.map(row => (
            <tr>
              <td class="py-2 pr-4 font-medium text-gray-500 w-1/3">{row.label}</td>
              <td class="py-2">{row.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- ステータス -->
  {(() => {
    const sMax = card.shout_max || 0;
    const bMax = card.beat_max || 0;
    const mMax = card.melody_max || 0;
    const total = sMax + bMax + mMax;
    const r = 15.9155;
    const c = 2 * Math.PI * r;
    const sLen = total ? (sMax / total) * c : 0;
    const bLen = total ? (bMax / total) * c : 0;
    const mLen = total ? (mMax / total) * c : 0;
    const sPct = total ? Math.round((sMax / total) * 100) : 0;
    const bPct = total ? Math.round((bMax / total) * 100) : 0;
    const mPct = total ? Math.round((mMax / total) * 100) : 0;
    return (
      <section class="bg-white rounded-lg shadow p-6 mb-6">
        <h2 class="text-lg font-semibold mb-4">ステータス</h2>
        <div class="flex flex-col sm:flex-row items-center gap-6">
          <div class="w-36 h-36 relative flex-shrink-0">
            <svg viewBox="0 0 36 36" class="w-full h-full">
              <circle cx="18" cy="18" r={r} fill="none" stroke="#e5e7eb" stroke-width="4" />
              <circle cx="18" cy="18" r={r} fill="none" stroke="#ef4444" stroke-width="4"
                stroke-dasharray={`${sLen} ${c - sLen}`} stroke-dashoffset="0" transform="rotate(-90 18 18)" />
              <circle cx="18" cy="18" r={r} fill="none" stroke="#22c55e" stroke-width="4"
                stroke-dasharray={`${bLen} ${c - bLen}`} stroke-dashoffset={-sLen} transform="rotate(-90 18 18)" />
              <circle cx="18" cy="18" r={r} fill="none" stroke="#3b82f6" stroke-width="4"
                stroke-dasharray={`${mLen} ${c - mLen}`} stroke-dashoffset={-(sLen + bLen)} transform="rotate(-90 18 18)" />
              <text x="18" y="17" text-anchor="middle" class="fill-gray-500" font-size="3">合計</text>
              <text x="18" y="21" text-anchor="middle" class="fill-gray-800 font-bold" font-size="4">{total.toLocaleString()}</text>
            </svg>
          </div>
          <div class="flex-1 w-full space-y-3">
            {stats.map((s, i) => {
              const pct = [sPct, bPct, mPct][i];
              return (
                <div class="flex items-center gap-3">
                  <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background:${s.color}`}></span>
                  <span class="font-medium text-sm w-16">{s.label}</span>
                  <span class="text-sm text-gray-500 w-10 text-right">{pct}%</span>
                  <span class="text-sm text-right flex-1">{s.min.toLocaleString()} ~ {s.max.toLocaleString()}</span>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    );
  })()}

  <!-- APスキル -->
  {card.ap_skill_name && (
    <section class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">APスキル</h2>
      <div class="mb-3 text-sm text-gray-600">
        <p><strong>スキル名:</strong> {card.ap_skill_name}</p>
        {card.ap_skill_type && <p><strong>タイプ:</strong> {card.ap_skill_type}</p>}
        {card.ap_skill_req && <p><strong>発動条件:</strong> {card.ap_skill_req}</p>}
      </div>
      {apSkillLevels.length > 0 && (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 text-left">
                <th class="px-3 py-2">Lv</th>
                <th class="px-3 py-2">発動回数</th>
                <th class="px-3 py-2">発動確率</th>
                <th class="px-3 py-2">効果値</th>
                <th class="px-3 py-2">効果率</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {apSkillLevels.map(lv => (
                <tr>
                  <td class="px-3 py-2">Lv{lv.lv}</td>
                  <td class="px-3 py-2">{lv.count ?? '-'}</td>
                  <td class="px-3 py-2">{lv.per != null ? lv.per + '%' : '-'}</td>
                  <td class="px-3 py-2">{lv.value ?? '-'}</td>
                  <td class="px-3 py-2">{lv.rate ?? '-'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  )}

  <!-- その他スキル -->
  {otherSkills.length > 0 && (
    <section class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">その他スキル</h2>
      <table class="w-full text-sm">
        <tbody class="divide-y divide-gray-100">
          {otherSkills.map(row => (
            <tr>
              <td class="py-2 pr-4 font-medium text-gray-500 w-1/3">{row.label}</td>
              <td class="py-2">{row.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <!-- ブローチ情報 -->
  {broachs.length > 0 && (
    <section class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">固有ブローチ</h2>
      <div class="space-y-3">
        {broachs.map((b: any) => (
          <div class="border rounded p-3">
            <p class="font-medium">{b.card_name || ''} - {b.name || ''}</p>
            <div class="flex gap-4 mt-2 text-sm">
              <span class="text-red-500">Shout: {b.shout ?? '-'}</span>
              <span class="text-blue-500">Beat: {b.beat ?? '-'}</span>
              <span class="text-green-500">Melody: {b.melody ?? '-'}</span>
            </div>
            {b.broach_type && <p class="text-xs text-gray-500 mt-1">種類: {b.broach_type}</p>}
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
