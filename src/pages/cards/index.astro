---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchCardsJson } from '../../lib/data/fetchCardsJson.js';
import { CHARACTERS, RARITIES, ATTRIBUTES, CARD_THUMB_BASE_URL, ATTRIBUTE_MAP, PAGE_SIZE } from '../../lib/constants';

const allCards = await fetchCardsJson() as any[];
const skillTypes = [...new Set(allCards.map((c: any) => c.ap_skill_type).filter(Boolean))].sort() as string[];

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="カード一覧">
  <h1 class="text-2xl font-bold mb-6">カード一覧</h1>

  <!-- 検索フォーム -->
  <div class="bg-white rounded-lg shadow p-4 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-3">
      <div>
        <label for="search-text" class="block text-xs font-medium text-gray-500 mb-1">名前検索</label>
        <input type="text" id="search-text" placeholder="カード名/キャラ名"
               class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
      </div>
      <div>
        <label for="search-rarity" class="block text-xs font-medium text-gray-500 mb-1">レアリティ</label>
        <select id="search-rarity" class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="">すべて</option>
          {RARITIES.map(r => <option value={r}>{r}</option>)}
        </select>
      </div>
      <div>
        <label for="search-attribute" class="block text-xs font-medium text-gray-500 mb-1">属性</label>
        <select id="search-attribute" class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="">すべて</option>
          {ATTRIBUTES.map(a => <option value={a.label}>{a.label}</option>)}
        </select>
      </div>
      <div>
        <label for="search-character" class="block text-xs font-medium text-gray-500 mb-1">キャラクター</label>
        <select id="search-character" class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="">すべて</option>
          {CHARACTERS.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div>
        <label for="search-skill" class="block text-xs font-medium text-gray-500 mb-1">スキルタイプ</label>
        <select id="search-skill" class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="">すべて</option>
          {skillTypes.map(s => <option value={s}>{s}</option>)}
        </select>
      </div>
      <div>
        <label for="sort-by" class="block text-xs font-medium text-gray-500 mb-1">ソート</label>
        <select id="sort-by" class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="id-desc">ID降順（新しい順）</option>
          <option value="id-asc">ID昇順（古い順）</option>
          <option value="stats-desc">ステータス合計（高い順）</option>
          <option value="stats-asc">ステータス合計（低い順）</option>
        </select>
      </div>
    </div>
    <div class="mt-3 flex items-center gap-3">
      <button id="btn-reset" class="text-sm text-indigo-600 hover:underline">条件リセット</button>
      <span id="result-count" class="text-sm text-gray-500">{allCards.length}件中 1~{Math.min(PAGE_SIZE, allCards.length)}件を表示</span>
    </div>
  </div>

  <!-- カードリスト -->
  <div id="card-list">
    <!-- デスクトップテーブル -->
    <div class="hidden md:block overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-100 text-left text-xs text-gray-500 uppercase">
            <th class="px-3 py-2 w-16">画像</th>
            <th class="px-3 py-2">ID</th>
            <th class="px-3 py-2">カード名</th>
            <th class="px-3 py-2">キャラ</th>
            <th class="px-3 py-2">レア</th>
            <th class="px-3 py-2">属性</th>
            <th class="px-3 py-2 w-20">属性比率</th>
            <th class="px-3 py-2 text-right">Shout</th>
            <th class="px-3 py-2 text-right">Beat</th>
            <th class="px-3 py-2 text-right">Melody</th>
            <th class="px-3 py-2">スキル</th>
            <th class="px-3 py-2 w-28 text-center">所持数</th>
          </tr>
        </thead>
        <tbody id="table-body" class="divide-y divide-gray-100">
        </tbody>
      </table>
    </div>
    <!-- モバイルカード -->
    <div id="mobile-cards" class="md:hidden space-y-3"></div>
  </div>

  <!-- ページネーション -->
  <div id="pagination" class="mt-6 flex flex-wrap items-center justify-center gap-2"></div>

  <!-- ビルド時に埋め込んだカードデータ -->
  <script type="application/json" id="card-data" set:html={JSON.stringify(allCards)}></script>
  <script define:vars={{ base, PAGE_SIZE, CARD_THUMB_BASE_URL, ATTRIBUTE_MAP }}>
    window.__BASE_URL__ = base;
    window.__PAGE_SIZE__ = PAGE_SIZE;
    window.__CARD_THUMB_BASE_URL__ = CARD_THUMB_BASE_URL;
    window.__ATTRIBUTE_MAP__ = ATTRIBUTE_MAP;
  </script>

  <script>
    const base = (window as any).__BASE_URL__ || '/i7/';
    const PAGE_SIZE = (window as any).__PAGE_SIZE__ || 100;
    const THUMB_URL = (window as any).__CARD_THUMB_BASE_URL__;
    const ATTR_MAP: Record<number, string> = (window as any).__ATTRIBUTE_MAP__;

    interface Card {
      ID: number;
      cardID: number;
      cardname: string;
      name: string;
      rarity: string;
      attribute: number;
      shout_max: number;
      beat_max: number;
      melody_max: number;
      ap_skill_type: string | null;
      [key: string]: any;
    }

    // ビルド時に埋め込んだデータを読み込み（ネットワーク通信なし）
    const allCards: Card[] = JSON.parse(document.getElementById('card-data')!.textContent!);
    let filtered: Card[] = [];
    let currentPage = 1;

    const $ = (id: string) => document.getElementById(id)!;

    // 所持数管理（localStorage）
    const STORAGE_KEY = 'i7_card_counts';
    function loadCounts(): Record<string, number> {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch { return {}; }
    }
    function saveCounts(counts: Record<string, number>) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(counts));
    }
    function getCount(cardId: number): number {
      return loadCounts()[String(cardId)] || 0;
    }
    function setCount(cardId: number, value: number) {
      const counts = loadCounts();
      const v = Math.max(0, value);
      if (v === 0) { delete counts[String(cardId)]; } else { counts[String(cardId)] = v; }
      saveCounts(counts);
    }
    function countControl(cardId: number): string {
      const count = getCount(cardId);
      return `<div class="flex items-center justify-center gap-1" onclick="event.stopPropagation()">
        <button data-count-btn="${cardId}" data-delta="-1"
          class="w-6 h-6 rounded bg-gray-200 hover:bg-gray-300 text-sm font-bold leading-none">−</button>
        <input type="number" data-count-input="${cardId}" value="${count}" min="0"
          class="w-10 h-6 text-center text-sm border border-gray-300 rounded [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
        <button data-count-btn="${cardId}" data-delta="1"
          class="w-6 h-6 rounded bg-gray-200 hover:bg-gray-300 text-sm font-bold leading-none">+</button>
      </div>`;
    }

    function rarityBadge(r: string): string {
      const c: Record<string, string> = { UR: 'bg-amber-500', SSR: 'bg-purple-500', SR: 'bg-sky-400', R: 'bg-gray-400', GROUP: 'bg-pink-400' };
      return `<span class="inline-block px-1.5 py-0.5 text-xs font-bold text-white rounded ${c[r] || 'bg-gray-300'}">${r}</span>`;
    }

    function attrBadge(a: string): string {
      const c: Record<string, string> = { Shout: 'bg-red-500', Beat: 'bg-green-500', Melody: 'bg-blue-500' };
      return `<span class="inline-block px-1.5 py-0.5 text-xs font-bold text-white rounded ${c[a] || 'bg-gray-300'}">${a || '?'}</span>`;
    }

    function statsPie(s: number, b: number, m: number): string {
      const total = s + b + m;
      if (!total) return '<span class="text-gray-400 text-xs">-</span>';
      const r = 15.9155;
      const c = 2 * Math.PI * r;
      const sLen = (s / total) * c;
      const bLen = (b / total) * c;
      const mLen = (m / total) * c;
      const sPct = Math.round((s / total) * 100);
      const bPct = Math.round((b / total) * 100);
      const mPct = Math.round((m / total) * 100);
      return `<svg viewBox="0 0 36 36" class="w-10 h-10" title="S:${sPct}% B:${bPct}% M:${mPct}%">
        <circle cx="18" cy="18" r="${r}" fill="none" stroke="#e5e7eb" stroke-width="5"/>
        <circle cx="18" cy="18" r="${r}" fill="none" stroke="#ef4444" stroke-width="5"
          stroke-dasharray="${sLen} ${c - sLen}" stroke-dashoffset="0" transform="rotate(-90 18 18)"/>
        <circle cx="18" cy="18" r="${r}" fill="none" stroke="#22c55e" stroke-width="5"
          stroke-dasharray="${bLen} ${c - bLen}" stroke-dashoffset="${-sLen}" transform="rotate(-90 18 18)"/>
        <circle cx="18" cy="18" r="${r}" fill="none" stroke="#3b82f6" stroke-width="5"
          stroke-dasharray="${mLen} ${c - mLen}" stroke-dashoffset="${-(sLen + bLen)}" transform="rotate(-90 18 18)"/>
      </svg>`;
    }

    function imgTag(cardID: number): string {
      return `<img src="${THUMB_URL}/${cardID}.png" alt="" class="w-12 h-auto rounded"
        onerror="this.onerror=null;this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 48 67%22><rect width=%2248%22 height=%2267%22 fill=%22%23e5e7eb%22/></svg>'" loading="lazy" />`;
    }

    const attrBg: Record<string, string> = { Shout: 'rgba(239,68,68,0.06)', Beat: 'rgba(34,197,94,0.06)', Melody: 'rgba(59,130,246,0.06)' };
    const attrBgHover: Record<string, string> = { Shout: 'rgba(239,68,68,0.12)', Beat: 'rgba(34,197,94,0.12)', Melody: 'rgba(59,130,246,0.12)' };

    function renderTableRow(card: Card): string {
      const bg = attrBg[card.attribute] || '';
      const bgH = attrBgHover[card.attribute] || 'rgba(0,0,0,0.02)';
      return `<tr class="cursor-pointer" style="background:${bg}" onmouseenter="this.style.background='${bgH}'" onmouseleave="this.style.background='${bg}'" onclick="location.href='${base}cards/${card.ID}/'">
        <td class="px-3 py-2">${imgTag(card.ID)}</td>
        <td class="px-3 py-2">${card.ID}</td>
        <td class="px-3 py-2" data-filter-cardname="${(card.cardname || '').replace(/"/g, '&quot;')}" onclick="event.stopPropagation()"><span class="text-indigo-600 hover:underline cursor-pointer">${card.cardname || ''}</span></td>
        <td class="px-3 py-2">${card.name || ''}</td>
        <td class="px-3 py-2">${rarityBadge(card.rarity)}</td>
        <td class="px-3 py-2">${attrBadge(card.attribute)}</td>
        <td class="px-3 py-2">${statsPie(card.shout_max || 0, card.beat_max || 0, card.melody_max || 0)}</td>
        <td class="px-3 py-2 text-right">${(card.shout_max || 0).toLocaleString()}</td>
        <td class="px-3 py-2 text-right">${(card.beat_max || 0).toLocaleString()}</td>
        <td class="px-3 py-2 text-right">${(card.melody_max || 0).toLocaleString()}</td>
        <td class="px-3 py-2 text-xs">${card.ap_skill_type || ''}</td>
        <td class="px-3 py-2">${countControl(card.ID)}</td>
      </tr>`;
    }

    function renderMobileCard(card: Card): string {
      const bg = attrBg[card.attribute] || '';
      return `<div class="rounded-lg shadow p-3 hover:shadow-md transition-shadow" style="background:${bg}">
        <div class="flex gap-3" onclick="location.href='${base}cards/${card.ID}/'" style="cursor:pointer">
          <div class="flex-shrink-0">${imgTag(card.ID)}</div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1 mb-1">${rarityBadge(card.rarity)} ${attrBadge(card.attribute)}</div>
            <p class="font-medium text-sm truncate" data-filter-cardname="${(card.cardname || '').replace(/"/g, '&quot;')}" onclick="event.stopPropagation()"><span class="text-indigo-600 hover:underline cursor-pointer">${card.cardname || ''}</span></p>
            <p class="text-xs text-gray-500">${card.name || ''}</p>
            <div class="flex items-center gap-2 mt-1">
              ${statsPie(card.shout_max || 0, card.beat_max || 0, card.melody_max || 0)}
              <div class="flex gap-2 text-xs">
                <span class="text-red-500">S:${card.shout_max || 0}</span>
                <span class="text-green-500">B:${card.beat_max || 0}</span>
                <span class="text-blue-500">M:${card.melody_max || 0}</span>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-2 flex items-center justify-between border-t pt-2">
          <span class="text-xs text-gray-500">所持数</span>
          ${countControl(card.ID)}
        </div>
      </div>`;
    }

    function renderPage() {
      const start = (currentPage - 1) * PAGE_SIZE;
      const page = filtered.slice(start, start + PAGE_SIZE);

      // htmx.swap でDOM更新
      const tableHtml = page.map(renderTableRow).join('');
      const mobileHtml = page.map(renderMobileCard).join('');

      if (typeof (window as any).htmx !== 'undefined') {
        (window as any).htmx.swap($('table-body'), tableHtml, { swapStyle: 'innerHTML' });
        (window as any).htmx.swap($('mobile-cards'), mobileHtml, { swapStyle: 'innerHTML' });
      } else {
        $('table-body').innerHTML = tableHtml;
        $('mobile-cards').innerHTML = mobileHtml;
      }

      // ページネーション
      const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
      let pagHtml = '';
      const btn = (p: number, label: string, active: boolean) =>
        `<button data-page="${p}" class="px-3 py-1 rounded text-sm ${active ? 'bg-indigo-600 text-white' : 'bg-white border border-gray-300 text-gray-700 hover:bg-gray-50'}">${label}</button>`;

      if (currentPage > 1) pagHtml += btn(currentPage - 1, '&laquo; 前', false);
      for (let p = 1; p <= totalPages; p++) {
        if (totalPages <= 7 || p <= 2 || p >= totalPages - 1 || Math.abs(p - currentPage) <= 1) {
          pagHtml += btn(p, String(p), p === currentPage);
        } else if (p === 3 && currentPage > 4) {
          pagHtml += '<span class="px-2 text-gray-400">...</span>';
        } else if (p === totalPages - 2 && currentPage < totalPages - 3) {
          pagHtml += '<span class="px-2 text-gray-400">...</span>';
        }
      }
      if (currentPage < totalPages) pagHtml += btn(currentPage + 1, '次 &raquo;', false);

      const pagEl = $('pagination');
      pagEl.innerHTML = pagHtml;
      pagEl.querySelectorAll('button[data-page]').forEach(b => {
        b.addEventListener('click', () => {
          currentPage = Number((b as HTMLElement).dataset.page);
          renderPage();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });

      $('result-count').textContent = `${filtered.length}件中 ${start + 1}~${Math.min(start + PAGE_SIZE, filtered.length)}件を表示`;

      // カード名クリック → 同名カードでフィルタ
      document.querySelectorAll<HTMLElement>('[data-filter-cardname]').forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const name = el.dataset.filterCardname || '';
          ($('search-text') as HTMLInputElement).value = name;
          applyFilters();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });

      // 所持数ボタン・入力イベント
      document.querySelectorAll<HTMLButtonElement>('button[data-count-btn]').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const cardId = Number(btn.dataset.countBtn);
          const delta = Number(btn.dataset.delta);
          const newVal = Math.max(0, getCount(cardId) + delta);
          setCount(cardId, newVal);
          document.querySelectorAll<HTMLInputElement>(`input[data-count-input="${cardId}"]`).forEach(inp => {
            inp.value = String(newVal);
          });
        });
      });
      document.querySelectorAll<HTMLInputElement>('input[data-count-input]').forEach(inp => {
        inp.addEventListener('change', (e) => {
          e.stopPropagation();
          const cardId = Number(inp.dataset.countInput);
          const val = Math.max(0, Number(inp.value) || 0);
          setCount(cardId, val);
          inp.value = String(val);
        });
        inp.addEventListener('click', (e) => e.stopPropagation());
      });
    }

    function applyFilters() {
      const text = ($('search-text') as HTMLInputElement).value.toLowerCase();
      const rarity = ($('search-rarity') as HTMLSelectElement).value;
      const attribute = ($('search-attribute') as HTMLSelectElement).value;
      const character = ($('search-character') as HTMLSelectElement).value;
      const skillType = ($('search-skill') as HTMLSelectElement).value;
      const sortBy = ($('sort-by') as HTMLSelectElement).value;

      filtered = allCards.filter(card => {
        if (text && !(card.cardname || '').toLowerCase().includes(text) &&
            !(card.name || '').toLowerCase().includes(text)) return false;
        if (rarity && card.rarity !== rarity) return false;
        if (attribute && card.attribute !== attribute) return false;
        if (character && card.name !== character) return false;
        if (skillType && card.ap_skill_type !== skillType) return false;
        return true;
      });

      switch (sortBy) {
        case 'id-asc':
          filtered.sort((a, b) => a.ID - b.ID);
          break;
        case 'stats-desc':
          filtered.sort((a, b) =>
            ((b.shout_max || 0) + (b.beat_max || 0) + (b.melody_max || 0)) -
            ((a.shout_max || 0) + (a.beat_max || 0) + (a.melody_max || 0)));
          break;
        case 'stats-asc':
          filtered.sort((a, b) =>
            ((a.shout_max || 0) + (a.beat_max || 0) + (a.melody_max || 0)) -
            ((b.shout_max || 0) + (b.beat_max || 0) + (b.melody_max || 0)));
          break;
        default:
          filtered.sort((a, b) => b.ID - a.ID);
      }

      currentPage = 1;
      renderPage();
      updateUrlParams();
    }

    function updateUrlParams() {
      const params = new URLSearchParams();
      const text = ($('search-text') as HTMLInputElement).value;
      const rarity = ($('search-rarity') as HTMLSelectElement).value;
      const attribute = ($('search-attribute') as HTMLSelectElement).value;
      const character = ($('search-character') as HTMLSelectElement).value;
      const skillType = ($('search-skill') as HTMLSelectElement).value;
      const sortBy = ($('sort-by') as HTMLSelectElement).value;

      if (text) params.set('q', text);
      if (rarity) params.set('rarity', rarity);
      if (attribute) params.set('attr', attribute);
      if (character) params.set('char', character);
      if (skillType) params.set('skill', skillType);
      if (sortBy !== 'id-desc') params.set('sort', sortBy);

      const qs = params.toString();
      history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
    }

    function restoreFromUrl() {
      const params = new URLSearchParams(location.search);
      if (params.get('q')) ($('search-text') as HTMLInputElement).value = params.get('q')!;
      if (params.get('rarity')) ($('search-rarity') as HTMLSelectElement).value = params.get('rarity')!;
      if (params.get('attr')) ($('search-attribute') as HTMLSelectElement).value = params.get('attr')!;
      if (params.get('char')) ($('search-character') as HTMLSelectElement).value = params.get('char')!;
      if (params.get('skill')) ($('search-skill') as HTMLSelectElement).value = params.get('skill')!;
      if (params.get('sort')) ($('sort-by') as HTMLSelectElement).value = params.get('sort')!;
    }

    // htmxイベントによるフィルタトリガー
    document.body.addEventListener('htmx:trigger', (e: any) => {
      if (e.detail?.name === 'filter-cards') {
        applyFilters();
      }
    });

    // フィルタ入力のイベント登録
    let debounceTimer: ReturnType<typeof setTimeout>;
    $('search-text').addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(applyFilters, 300);
    });
    for (const id of ['search-rarity', 'search-attribute', 'search-character', 'search-skill', 'sort-by']) {
      $(id).addEventListener('change', applyFilters);
    }
    $('btn-reset').addEventListener('click', () => {
      ($('search-text') as HTMLInputElement).value = '';
      ['search-rarity', 'search-attribute', 'search-character', 'search-skill'].forEach(id =>
        ($(id) as HTMLSelectElement).value = '');
      ($('sort-by') as HTMLSelectElement).value = 'id-desc';
      applyFilters();
    });

    // URLからフィルタ復元して初期表示
    restoreFromUrl();
    applyFilters();
  </script>
</BaseLayout>
