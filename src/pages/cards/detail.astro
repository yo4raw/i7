---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="カード詳細">
  <div id="loading" class="text-center py-12 text-gray-500">読み込み中...</div>
  <div id="error" class="hidden text-center py-12 text-red-500"></div>
  <div id="card-detail" class="hidden">
    <!-- カード画像 + 基本情報 -->
    <div class="mb-6">
      <a href={`${import.meta.env.BASE_URL}cards/`} class="text-indigo-600 hover:underline text-sm">&larr; カード一覧に戻る</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="md:col-span-1">
        <img id="card-image" src="" alt="" class="w-full rounded-lg shadow-md bg-gray-200"
             onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 200 280%22><rect width=%22200%22 height=%22280%22 fill=%22%23e5e7eb%22/><text x=%2250%25%22 y=%2250%25%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 fill=%22%239ca3af%22 font-size=%2216%22>No Image</text></svg>'" />
      </div>
      <div class="md:col-span-2">
        <h1 id="card-title" class="text-2xl font-bold mb-4"></h1>
        <table class="w-full text-sm">
          <tbody id="basic-info" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </div>

    <!-- ステータス -->
    <section class="bg-white rounded-lg shadow p-6 mb-6">
      <h2 class="text-lg font-semibold mb-4">ステータス</h2>
      <div id="stats-bars" class="space-y-3"></div>
    </section>

    <!-- APスキル -->
    <section id="ap-skill-section" class="bg-white rounded-lg shadow p-6 mb-6 hidden">
      <h2 class="text-lg font-semibold mb-4">APスキル</h2>
      <div id="ap-skill-info" class="mb-3 text-sm text-gray-600"></div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-left">
              <th class="px-3 py-2">Lv</th>
              <th class="px-3 py-2">発動回数</th>
              <th class="px-3 py-2">発動確率</th>
              <th class="px-3 py-2">効果値</th>
              <th class="px-3 py-2">効果率</th>
            </tr>
          </thead>
          <tbody id="ap-skill-table" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </section>

    <!-- CTスキル / SPスキル -->
    <section id="other-skills" class="bg-white rounded-lg shadow p-6 mb-6 hidden">
      <h2 class="text-lg font-semibold mb-4">その他スキル</h2>
      <table class="w-full text-sm">
        <tbody id="other-skills-body" class="divide-y divide-gray-100"></tbody>
      </table>
    </section>

    <!-- ブローチ情報 -->
    <section id="broach-section" class="bg-white rounded-lg shadow p-6 mb-6 hidden">
      <h2 class="text-lg font-semibold mb-4">固有ブローチ</h2>
      <div id="broach-list" class="space-y-3"></div>
    </section>
  </div>

  <script>
    import { fetchCardsJson } from '../../lib/data/fetchCardsJson.js';
    import { fetchFixedBroachsJson } from '../../lib/data/fetchFixedBroachsJson.js';
    import { CARD_IMAGE_BASE_URL, ATTRIBUTE_MAP } from '../../lib/constants';

    const ATTR_COLORS: Record<number, string> = { 1: '#ef4444', 2: '#3b82f6', 3: '#22c55e' };

    function getCardId(): number | null {
      const params = new URLSearchParams(window.location.search);
      const id = params.get('id');
      return id ? Number(id) : null;
    }

    function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
    function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }

    function infoRow(label: string, value: string | number | null | undefined): string {
      if (value == null || value === '') return '';
      return `<tr><td class="py-2 pr-4 font-medium text-gray-500 w-1/3">${label}</td><td class="py-2">${value}</td></tr>`;
    }

    function statBar(label: string, min: number, max: number, color: string): string {
      const pct = Math.min((max / 20000) * 100, 100);
      return `
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="font-medium">${label}</span>
            <span>${min.toLocaleString()} ~ ${max.toLocaleString()}</span>
          </div>
          <div class="h-3 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full rounded-full" style="width:${pct}%;background:${color}"></div>
          </div>
        </div>`;
    }

    function rarityBadge(rarity: string): string {
      const colors: Record<string, string> = {
        UR: 'bg-amber-500', SSR: 'bg-purple-500', SR: 'bg-sky-400', R: 'bg-gray-400', GROUP: 'bg-pink-400',
      };
      const cls = colors[rarity] || 'bg-gray-300';
      return `<span class="inline-block px-2 py-0.5 text-xs font-bold text-white rounded ${cls}">${rarity}</span>`;
    }

    function attrBadge(attr: number): string {
      const label = ATTRIBUTE_MAP[attr] || '不明';
      const colors: Record<number, string> = { 1: 'bg-red-500', 2: 'bg-blue-500', 3: 'bg-green-500' };
      const cls = colors[attr] || 'bg-gray-300';
      return `<span class="inline-block px-2 py-0.5 text-xs font-bold text-white rounded ${cls}">${label}</span>`;
    }

    async function loadCardDetail() {
      const cardId = getCardId();
      if (!cardId) {
        hide('loading');
        show('error');
        document.getElementById('error')!.textContent = 'カードIDが指定されていません。';
        return;
      }

      try {
        const [cards, broachs] = await Promise.all([fetchCardsJson(), fetchFixedBroachsJson()]);
        const card = (cards as any[]).find((c: any) => c.ID === cardId || c.cardID === cardId);

        if (!card) {
          hide('loading');
          show('error');
          document.getElementById('error')!.textContent = `カードID ${cardId} が見つかりませんでした。`;
          return;
        }

        // 画像
        const img = document.getElementById('card-image') as HTMLImageElement;
        img.src = `${CARD_IMAGE_BASE_URL}/${card.cardID}.png`;
        img.alt = card.cardname || '';

        // タイトル
        document.getElementById('card-title')!.innerHTML =
          `${rarityBadge(card.rarity)} ${attrBadge(card.attribute)} ${card.cardname || ''}`;

        // 基本情報
        document.getElementById('basic-info')!.innerHTML = [
          infoRow('ID', card.ID),
          infoRow('カードID', card.cardID),
          infoRow('キャラクター', card.name),
          infoRow('グループ', card.groupname),
          infoRow('入手方法', card.get_type),
          infoRow('ストーリー', card.story),
        ].join('');

        // ステータスバー
        const maxVal = Math.max(card.shout_max || 0, card.beat_max || 0, card.melody_max || 0, 1);
        document.getElementById('stats-bars')!.innerHTML = [
          statBar('Shout', card.shout_min || 0, card.shout_max || 0, ATTR_COLORS[1]),
          statBar('Beat', card.beat_min || 0, card.beat_max || 0, ATTR_COLORS[2]),
          statBar('Melody', card.melody_min || 0, card.melody_max || 0, ATTR_COLORS[3]),
        ].join('');

        // APスキル
        if (card.ap_skill_name) {
          show('ap-skill-section');
          document.getElementById('ap-skill-info')!.innerHTML = [
            `<p><strong>スキル名:</strong> ${card.ap_skill_name}</p>`,
            card.ap_skill_type ? `<p><strong>タイプ:</strong> ${card.ap_skill_type}</p>` : '',
            card.ap_skill_req ? `<p><strong>発動条件:</strong> ${card.ap_skill_req}</p>` : '',
          ].join('');

          let rows = '';
          for (let i = 1; i <= 5; i++) {
            const count = card[`ap_skill_${i}_count`];
            const per = card[`ap_skill_${i}_per`];
            const value = card[`ap_skill_${i}_value`];
            const rate = card[`ap_skill_${i}_rate`];
            if (count != null || per != null || value != null || rate != null) {
              rows += `<tr>
                <td class="px-3 py-2">Lv${i}</td>
                <td class="px-3 py-2">${count ?? '-'}</td>
                <td class="px-3 py-2">${per != null ? per + '%' : '-'}</td>
                <td class="px-3 py-2">${value ?? '-'}</td>
                <td class="px-3 py-2">${rate ?? '-'}</td>
              </tr>`;
            }
          }
          document.getElementById('ap-skill-table')!.innerHTML = rows;
        }

        // その他スキル
        if (card.ct_skill || card.sp_time || card.sp_value || card.comment) {
          show('other-skills');
          document.getElementById('other-skills-body')!.innerHTML = [
            infoRow('センタースキル', card.ct_skill),
            infoRow('SPスキル時間', card.sp_time),
            infoRow('SPスキル値', card.sp_value),
            infoRow('コメント', card.comment),
          ].join('');
        }

        // ブローチ
        const cardBroachs = (broachs as any[]).filter((b: any) => b.card_id === card.cardID);
        if (cardBroachs.length > 0) {
          show('broach-section');
          document.getElementById('broach-list')!.innerHTML = cardBroachs.map((b: any) => `
            <div class="border rounded p-3">
              <p class="font-medium">${b.card_name || ''} - ${b.name || ''}</p>
              <div class="flex gap-4 mt-2 text-sm">
                <span class="text-red-500">Shout: ${b.shout ?? '-'}</span>
                <span class="text-blue-500">Beat: ${b.beat ?? '-'}</span>
                <span class="text-green-500">Melody: ${b.melody ?? '-'}</span>
              </div>
              ${b.broach_type ? `<p class="text-xs text-gray-500 mt-1">種類: ${b.broach_type}</p>` : ''}
            </div>
          `).join('');
        }

        hide('loading');
        show('card-detail');

      } catch (e) {
        console.error('データ取得エラー:', e);
        hide('loading');
        show('error');
        document.getElementById('error')!.textContent = 'データの取得に失敗しました。';
      }
    }

    loadCardDetail();
  </script>
</BaseLayout>
